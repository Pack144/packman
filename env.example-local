# .env for local development with Pack 144 defaults.
# Copy to .env and adjust as needed.
# For production settings see env.example and packman/settings/production.py.
#
# DJANGO_SETTINGS_MODULE is set by util/start_local.sh — no need to set it here.


# PACK SPECIFIC
# -------------------------------------------------------------------
PACK_NAME="Cub Scouts Pack 144"
PACK_SHORTNAME="Pack 144"
PACK_DOMAIN_NAME="pack144.org"
PACK_LOCATION="Seattle, Washington"
PACK_TAGLINE="Since 1929"
PACK_YEAR_BEGIN_MONTH=7
PACK_YEAR_BEGINS_DAY=1


# SECURITY
# A placeholder key is fine for local dev — never use this in production.
# -------------------------------------------------------------------
DJANGO_SECRET_KEY="django-insecure-replace-me-for-local-dev-only"
# DEBUG defaults to True in local settings; uncomment to override
# DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"


# DATABASE
# Leave commented to use the default db.sqlite3 in the project root.
# To run against a production backup converted with util/pg_to_sqlite.py, set an
# absolute path here — see "Running locally with a production backup" in README.
# -------------------------------------------------------------------
# DATABASE_URL="sqlite:////path/to/backup.sqlite3"


# EMAIL
# consolemail:// prints emails to the terminal instead of sending them.
# -------------------------------------------------------------------
DJANGO_EMAIL_URL="consolemail://"
DJANGO_ADMINS="Pack Admin:admin@pack144.org"
DJANGO_DEFAULT_FROM_EMAIL="no-reply@pack144.org"


# LOCALIZATION
# -------------------------------------------------------------------
TIME_ZONE="America/Los_Angeles"
